##---------- System (super / super + shift) ----------##
# Terminal
alt + Return
	kitty

# TDrop (scratchpad)
# alt + shift + Return
# 	tdrop -ma -A -w 50% -x 25% -s dropdown kitty

# Lockscreen
alt + shift  + p
	xset s activate

# Reload Keybindings
alt + BackSpace
	pkill -USR1 -x sxhkd

# Dmenu Network Menu
alt + n
	networkmanager_dmenu

# Linux-notification-center
alt + shift + n
	kill -s USR1 $(pidof deadd-notification-center)

# kill window
alt + shift + Escape
    xkil

# change theme
alt + t
	bash ~/.local/bin/theme_changer

# powermenu
alt + x
	bash ~/.local/bin/powermenu

# Keybindings Cheatsheet
alt + ctrl + k
	bash ~/.local/bin/dwm_keybindings

# dmenu
alt + d
	dmenu_run -l 9 -p "﩯 " 

# show desktop applications
alt + a
	bash ~/.local/bin/dmenu_app

##---------- Other programs or scripts (super + ctrl) ----------##

# Redshift
alt + ctrl + r
  redshift -P -O 5000

alt + ctrl + e
	redshift -x

# Color Picker
alt + ctrl + p
	gpick

##---------- Applications (super + alt) ----------##

# File Manager
alt + shift + f
	nemo

# Browser
alt + shift + b
	firefox

# Terminal Apps
alt + shift  + v
	kitty -e vim


##---------- System Keys ----------##

# Take a screenshot
Print
	flameshot full -p $HOME/Pictures/SS/

# # Take a screenshot with gui selection
super + Print
	flameshot gui
	
# # Take screenshot in 5 second
alt + Print	
	flameshot full -d 5000 -p $HOME/Pictures/SS/

# # Take screenshot in 10 second
shift + Print	
	flameshot full -d 10000 -p $HOME/Pictures/SS/

# Brighness control
# XF86MonBrightness{Up,Down}
	# xbacklight{ -inc 5, -dec 5}

#Player ctl
alt + p
	playerctl play-pause

XF86MonBrightnessUp
	brightnessctl set +5%

XF86MonBrightnessDown
	brightnessctl set 5%-

	
# Volume control
XF86AudioRaiseVolume
	pactl set-sink-volume 0 +5%

XF86AudioLowerVolume
	pactl set-sink-volume 0 -5%

XF86AudioMute
	pactl set-sink-mute 0 toggle


